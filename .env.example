NEXT_PUBLIC_SITE_URL=https://ezysmartshop.com
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_replace
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace
NEXT_PUBLIC_FIREBASE_API_KEY=replace
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace
