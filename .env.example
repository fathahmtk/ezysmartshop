# ── Shopify Storefront API (optional) ───────────────────────────────────────
# Set both variables to activate the Shopify integration.
# Products, categories, and cart will be served by your Shopify store.
# Checkout will redirect to Shopify's native checkout.
# Leave blank to use the built-in custom backend / demo data instead.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token
# ────────────────────────────────────────────────────────────────────────────

PORT=4000
NODE_ENV=development
DEMO_MODE=true
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://ezysmartshop.com
JWT_SECRET=replace_with_long_random_value
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ezysmartshop
REDIS_URL=redis://localhost:6379
FIREBASE_PROJECT_ID=replace
FIREBASE_CLIENT_EMAIL=replace
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_ID=replace
GOOGLE_CLIENT_SECRET=replace
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
RAZORPAY_KEY_ID=rzp_test_replace
RAZORPAY_KEY_SECRET=replace
GEMINI_API_KEY=replace
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace
SMTP_PASS=replace
AWS_ACCESS_KEY_ID=replace
